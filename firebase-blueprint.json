{
  "entities": {
    "Car": {
      "title": "Car",
      "description": "A rental car in the fleet.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The car's make and model." },
        "plateNumber": { "type": "string", "description": "The car's license plate number." },
        "type": { "type": "string", "description": "The category of the car (e.g., Sedan, SUV, Economy, Truck)." },
        "category": { "type": "string", "enum": ["Car", "Motorbike", "Other"], "description": "Vehicle category." },
        "make": { "type": "string", "description": "Vehicle make (e.g., Toyota)." },
        "makeLogoUrl": { "type": "string", "description": "URL to the make's logo." },
        "model": { "type": "string", "description": "Vehicle model (e.g., Vios)." },
        "yearOfManufacture": { "type": "integer", "description": "Year of manufacture." },
        "insuranceExpiry": { "type": "string", "format": "date", "description": "Insurance expiry date." },
        "taxExpiry": { "type": "string", "format": "date", "description": "Tax expiry date." },
        "owner": { "type": "string", "description": "Who owns the vehicle." },
        "currentKms": { "type": "integer", "description": "Current mileage." },
        "lastOilChangeKms": { "type": "integer", "description": "Mileage at last oil change." },
        "lastOilChangeDate": { "type": "string", "format": "date", "description": "Date of last oil change." },
        "order": { "type": "integer", "description": "The display order of the car." },
        "pricePerDay": { "type": "number", "description": "Daily rental price in THB." },
        "imageUrl": { "type": "string", "description": "URL to the car image." },
        "seats": { "type": "integer", "description": "Number of seats." },
        "transmission": { "type": "string", "description": "Transmission type (Auto/Manual)." },
        "engine": { "type": "string", "description": "Engine capacity." },
        "fuel": { "type": "string", "description": "Fuel type." },
        "modelYear": { "type": "string", "description": "Model year range." },
        "isActive": { "type": "boolean", "description": "Whether the vehicle is currently active in the fleet." },
        "audio": { "type": "string", "description": "Audio system details." }
      },
      "required": ["name", "plateNumber", "type", "order", "category", "make", "model", "yearOfManufacture"]
    },
    "VehicleLog": {
      "title": "VehicleLog",
      "description": "Activity, maintenance, or notes for a vehicle.",
      "type": "object",
      "properties": {
        "carId": { "type": "string", "description": "The ID of the car." },
        "type": { "type": "string", "enum": ["Activity", "Maintenance", "Note"], "description": "The type of log entry." },
        "date": { "type": "string", "format": "date-time", "description": "The date of the log entry." },
        "user": { "type": "string", "description": "The user who created the log." },
        "description": { "type": "string", "description": "A description of the entry." },
        "details": { "type": "object", "description": "Optional structured details about changes." }
      },
      "required": ["carId", "type", "date", "user", "description"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer who rents vehicles.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string", "description": "Customer's first name." },
        "lastName": { "type": "string", "description": "Customer's last name (Surname)." },
        "email": { "type": "string", "format": "email", "description": "Customer's unique email address." },
        "mobileNumber": { "type": "string", "description": "Customer's contact number." },
        "address": { "type": "string", "description": "Customer's physical address." },
        "addressHotel": { "type": "string", "description": "Customer's hotel or temporary address." },
        "dob": { "type": "string", "format": "date", "description": "Customer's date of birth." },
        "drivingLicence": { "type": "string", "description": "Customer's driving licence number." },
        "bikeLicenceExpiry": { "type": "string", "format": "date", "description": "Bike licence expiry date." },
        "carLicenceExpiry": { "type": "string", "format": "date", "description": "Car licence expiry date." },
        "notes": { "type": "string", "description": "Additional notes about the customer." },
        "creationDate": { "type": "string", "format": "date-time", "description": "When the customer record was created." },
        "uniqueId": { "type": "string", "description": "A unique identifier for the customer." },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        }
      },
      "required": ["firstName", "email"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A rental reservation for a car.",
      "type": "object",
      "properties": {
        "carId": { "type": "string", "description": "The ID of the car being rented." },
        "customerName": { "type": "string", "description": "The name of the customer." },
        "email": { "type": "string", "format": "email", "description": "The email of the customer." },
        "mobileNumber": { "type": "string", "description": "The customer's contact number." },
        "startDate": { "type": "string", "format": "date-time", "description": "The start date and time of the booking." },
        "endDate": { "type": "string", "format": "date-time", "description": "The end date and time of the booking." },
        "status": { "type": "string", "enum": ["Paid", "Pending"], "description": "The payment status of the booking." },
        "amount": { "type": "number", "description": "The total rental amount." },
        "notes": { "type": "string", "description": "Additional notes for the booking." },
        "deliveryAddress": { "type": "string", "description": "The delivery address for the vehicle." },
        "deliveryLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "deliveryNotes": { "type": "string", "description": "Internal notes for the delivery." },
        "returnNote": { "type": "string", "description": "Specific notes for when the car is returned." },
        "nationality": { "type": "string", "description": "Customer's nationality." },
        "utmSource": { "type": "string", "description": "UTM source param captured from booking URL (e.g. google, facebook)." },
        "utmMedium": { "type": "string", "description": "UTM medium param (e.g. cpc, organic, social)." },
        "utmCampaign": { "type": "string", "description": "UTM campaign name." },
        "bookingSource": { "type": "string", "description": "Staff-assigned booking channel: google_ads | google_organic | facebook | direct | referral | walk_in | other." }
      },
      "required": ["carId", "customerName", "startDate", "endDate", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "An income or expense record.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["Income", "Expense", "Transfer"], "description": "The type of transaction." },
        "amount": { "type": "number", "description": "The transaction amount." },
        "date": { "type": "string", "format": "date-time", "description": "The date of the transaction." },
        "category": { "type": "string", "description": "The category (e.g., Rental, Maintenance, Rent)." },
        "carId": { "type": "string", "description": "Optional car ID associated with the transaction." },
        "vehicleFinanceId": { "type": "string", "description": "Optional finance record ID associated with a loan repayment." },
        "accountId": { "type": "string", "description": "The account associated with the transaction." },
        "toAccountId": { "type": "string", "description": "The destination account for transfers." },
        "description": { "type": "string", "description": "A brief description of the transaction." }
      },
      "required": ["type", "amount", "date", "accountId"]
    },
    "Account": {
      "title": "Account",
      "description": "A bank account or cash fund.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the account." },
        "balance": { "type": "number", "description": "The current balance of the account." }
      },
      "required": ["name", "balance"]
    },
    "PricingRule": {
      "title": "PricingRule",
      "description": "Standard pricing tiers for a car type.",
      "type": "object",
      "properties": {
        "carType": { "type": "string", "description": "The category of the car." },
        "rates": {
          "type": "object",
          "description": "A map of duration tiers to daily rates.",
          "properties": {
            "1-3": { "type": "number" },
            "4-7": { "type": "number" },
            "8-14": { "type": "number" },
            "15-29": { "type": "number" },
            "30+": { "type": "number" }
          }
        }
      },
      "required": ["carType", "rates"]
    },
    "PricingGrid": {
      "title": "PricingGrid",
      "description": "Date-specific pricing grid for a car type.",
      "type": "object",
      "properties": {
        "carType": { "type": "string" },
        "headers": { "type": "array", "items": { "type": "number" }, "description": "Duration headers (e.g. 1, 1.5, 2...)" },
        "rates": { 
          "type": "object", 
          "description": "Map of ISO date strings to arrays of rates matching headers.",
          "additionalProperties": { "type": "array", "items": { "type": "number" } }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["carType", "headers", "rates"]
    },
    "Mail": {
      "title": "Mail",
      "description": "A document used to trigger an email via the Firebase Trigger Email extension.",
      "type": "object",
      "properties": {
        "to": { "type": "string", "description": "Recipient email address." },
        "message": {
          "type": "object",
          "properties": {
            "subject": { "type": "string" },
            "text": { "type": "string" },
            "html": { "type": "string" }
          }
        }
      },
      "required": ["to", "message"]
    },
    "Rental": {
      "title": "Rental",
      "description": "An active rental record.",
      "type": "object",
      "properties": {
        "bookingId": { "type": "string", "description": "Optional booking ID." },
        "customerId": { "type": "string", "description": "The ID of the customer." },
        "carId": { "type": "string", "description": "The ID of the vehicle." },
        "dateOut": { "type": "string", "format": "date-time" },
        "dateIn": { "type": "string", "format": "date-time" },
        "totalCharge": { "type": "number" },
        "depositAmount": { "type": "number" },
        "damagePhotos": { "type": "array", "items": { "type": "string" }, "description": "List of storage URLs for damage photos." },
        "status": { "type": "string", "enum": ["Active", "Completed", "Cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "processedBy": { "type": "string" }
      },
      "required": ["customerId", "carId", "dateOut", "dateIn", "totalCharge", "status"]
    },
    "RentalPhoto": {
      "title": "RentalPhoto",
      "description": "A photo associated with a rental, used as a fallback when storage is unavailable.",
      "type": "object",
      "properties": {
        "rentalId": { "type": "string" },
        "photo": { "type": "string", "description": "Base64 encoded image data." },
        "index": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["rentalId", "photo", "createdAt"]
    },
    "WebsiteCar": {
      "title": "WebsiteCar",
      "description": "A vehicle displayed on the public website.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "yearRange": { "type": "string" },
        "pricePerDay": { "type": "number" },
        "priceMonthly": { "type": "number" },
        "engineSize": { "type": "string" },
        "fuelType": { "type": "string" },
        "transmission": { "type": "string" },
        "passengers": { "type": "integer" },
        "airCon": { "type": "boolean" },
        "audio": { "type": "string" },
        "displayOrder": { "type": "integer" },
        "isActive": { "type": "boolean" },
        "mainImage": { "type": "string" },
        "shadowImage": { "type": "string" },
        "realImages": { "type": "array", "items": { "type": "string" } },
        "slug": { "type": "string" },
        "priceGridVehicle": { "type": "string" }
      },
      "required": ["name", "displayOrder", "isActive"]
    },
    "SystemLog": {
      "title": "SystemLog",
      "description": "A log of system-wide activity.",
      "type": "object",
      "properties": {
        "action": { "type": "string", "description": "The action performed (e.g., 'Booking Created')." },
        "description": { "type": "string", "description": "A detailed description of what changed." },
        "user": { "type": "string", "description": "The email or name of the user who performed the action." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the action occurred." },
        "category": { "type": "string", "description": "The area of the system (e.g., 'Bookings', 'Fleet', 'CRM')." },
        "metadata": { "type": "object", "description": "Optional additional data about the change." }
      },
      "required": ["action", "description", "user", "timestamp", "category"]
    },
    "SystemConfig": {
      "title": "SystemConfig",
      "description": "System-wide configuration settings, including OAuth tokens.",
      "type": "object",
      "properties": {
        "tokens": {
          "type": "object",
          "description": "OAuth tokens for external services (e.g., Gmail)."
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "User": {
      "title": "User",
      "description": "A staff user with specific roles.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "displayName": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "When the user last logged in." }
      },
      "required": ["email", "role"]
    },
    "FAQ": {
      "title": "FAQ",
      "description": "A frequently asked question.",
      "type": "object",
      "properties": {
        "q": { "type": "string", "description": "The question." },
        "a": { "type": "string", "description": "The answer." },
        "category": { "type": "string", "description": "The category of the FAQ." },
        "order": { "type": "integer", "description": "The display order." }
      },
      "required": ["q", "a", "category"]
    },
    "Setting": {
      "title": "Setting",
      "description": "A system setting.",
      "type": "object",
      "properties": {
        "spreadsheetId": { "type": "string" },
        "enabled": { "type": "boolean" }
      }
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "A blog post for the website.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "author": { "type": "string" },
        "authorId": { "type": "string" },
        "coverImage": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["Draft", "Published"] },
        "publishedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content", "author", "authorId", "status", "createdAt", "updatedAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "description": "e.g., Google, Website, Facebook" },
        "reply": { "type": "string", "description": "The response to the review." },
        "repliedAt": { "type": "string", "format": "date-time" },
        "isAutomated": { "type": "boolean" }
      },
      "required": ["customerName", "rating", "comment", "date"]
    },
    "ReviewSettings": {
      "title": "ReviewSettings",
      "description": "Settings for review management.",
      "type": "object",
      "properties": {
        "autoReplyEnabled": { "type": "boolean" },
        "autoReplyTemplate": { "type": "string" },
        "minRatingForAutoReply": { "type": "integer" }
      }
    },
    "Enquiry": {
      "title": "Enquiry",
      "description": "A general enquiry from the website.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "to": { "type": "string" },
        "source_domain": { "type": "string" }
      },
      "required": ["name", "email", "message", "timestamp"]
    },
    "ContentCalendarItem": {
      "title": "ContentCalendarItem",
      "description": "An item in the content marketing calendar.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "targetKeyword": { "type": "string" },
        "targetUrl": { "type": "string" },
        "publishDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Idea", "In Progress", "Scheduled", "Published"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "seoData": { "type": "object" },
        "analyticsData": { "type": "object" }
      },
      "required": ["title", "status", "createdAt"]
    },
    "FinanceSummary": {
      "title": "FinanceSummary",
      "description": "Aggregated financial totals (monthly or all-time).",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["monthly", "all-time"] },
        "month": { "type": "string", "description": "YYYY-MM format for monthly summaries." },
        "totalIncome": { "type": "number" },
        "totalExpense": { "type": "number" },
        "netProfit": { "type": "number" },
        "accountBalances": {
          "type": "object",
          "description": "Map of accountId to balance at the time of summary.",
          "additionalProperties": { "type": "number" }
        },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "totalIncome", "totalExpense", "netProfit", "lastUpdated"]
    },
    "MarketingPage": {
      "title": "MarketingPage",
      "description": "A standalone marketing page for the website.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "categoryPath": { "type": "string", "description": "e.g., /cars/ev-rentals" },
        "content": { "type": "string", "description": "HTML content for the page." },
        "excerpt": { "type": "string" },
        "featuredImageUrl": { "type": "string" },
        "featuredImageAlt": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Published"] },
        "layoutType": { "type": "string", "enum": ["Service", "Location", "Blog", "Home", "Landing", "Contact", "About", "FAQ", "Fleet", "Custom"] },
        "metaDescription": { "type": "string" },
        "keywords": { "type": "string" },
        "canonicalUrl": { "type": "string" },
        "schemaMarkup": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "fullUrl": { "type": "string", "description": "Combines categoryPath and slug." }
      },
      "required": ["title", "slug", "status", "layoutType", "createdAt", "updatedAt"]
    },
    "CompanyConfig": {
      "title": "CompanyConfig",
      "description": "Global business information.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "lineId": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "googlePlaceId": { "type": "string" },
        "mapEmbedUrl": { "type": "string" },
        "openingHours": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
    "VehicleFinance": {
      "title": "VehicleFinance",
      "description": "Repayment and loan details for a financed vehicle.",
      "type": "object",
      "properties": {
        "vehicleId": { "type": "string", "description": "Reference to the fleet vehicle ID." },
        "lender": { "type": "string", "description": "e.g., K-Bank, SCB." },
        "totalLoanAmount": { "type": "number", "description": "Original loan principal." },
        "monthlyInstallment": { "type": "number", "description": "Fixed monthly payment." },
        "totalInstallments": { "type": "number", "description": "Total number of months." },
        "startDate": { "type": "string", "format": "date-time" },
        "interestRate": { "type": "number" }
      },
      "required": ["vehicleId", "lender", "totalLoanAmount", "monthlyInstallment", "totalInstallments", "startDate"]
    }
  },
  "firestore": {
    "/cars/{carId}": {
      "schema": "Car",
      "description": "Collection of rental cars."
    },
    "/vehicle_logs/{logId}": {
      "schema": "VehicleLog",
      "description": "Activity and maintenance logs for vehicles."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of car rental bookings."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Collection of financial transactions."
    },
    "/accounts/{accountId}": {
      "schema": "Account",
      "description": "Collection of bank accounts and cash funds."
    },
    "/pricing/{pricingId}": {
      "schema": "PricingRule",
      "description": "Collection of standard pricing rules."
    },
    "/pricing_grid/{carType}": {
      "schema": "PricingGrid",
      "description": "Collection of date-specific pricing grids."
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of customer profiles."
    },
    "/mail/{mailId}": {
      "schema": "Mail",
      "description": "Collection used for triggering emails."
    },
    "/rentals/{rentalId}": {
      "schema": "Rental",
      "description": "Collection of active rental records."
    },
    "/rental_photos/{photoId}": {
      "schema": "RentalPhoto",
      "description": "Collection of rental photos (fallback storage)."
    },
    "/website_cars/{carId}": {
      "schema": "WebsiteCar",
      "description": "Collection of vehicles displayed on the public website."
    },
    "/system_logs/{logId}": {
      "schema": "SystemLog",
      "description": "Collection of system-wide activity logs."
    },
    "/system_config/{configId}": {
      "schema": "SystemConfig",
      "description": "System configuration settings."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of staff users."
    },
    "/faqs/{faqId}": {
      "schema": "FAQ",
      "description": "Collection of frequently asked questions."
    },
    "/settings/{settingId}": {
      "schema": "Setting",
      "description": "Collection of system settings."
    },
    "/blog_posts/{postId}": {
      "schema": "BlogPost",
      "description": "Collection of blog posts."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of customer reviews."
    },
    "/review_settings/{settingId}": {
      "schema": "ReviewSettings",
      "description": "Settings for review management."
    },
    "/marketing_pages/{pageId}": {
      "schema": "MarketingPage",
      "description": "Collection of standalone marketing pages."
    },
    "/finance_summaries/{summaryId}": {
      "schema": "FinanceSummary",
      "description": "Aggregated financial summaries (monthly and all-time)."
    },
    "/app_settings/company": {
      "schema": "CompanyConfig",
      "description": "Global company information."
    },
    "/enquiries/{enquiryId}": {
      "schema": "Enquiry",
      "description": "Collection of general enquiries."
    },
    "/contentCalendar/{itemId}": {
      "schema": "ContentCalendarItem",
