rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    match /marketing_pages/{pageId} {
      allow get, list: if true;
    }

    match /faqs/{faqId} {
      allow get, list: if true;
    }

    match /cars/{carId} {
      allow get, list: if true;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.email.lower() == "info@pattayarentacar.com"
      );
    }
    
    function getEmail() {
      return isSignedIn() ? request.auth.token.email.lower() : "";
    }
    
    function isAdmin() {
      let email = getEmail();
      return isSignedIn() && (
        email in [
          "info@pattayarentacar.com",
          "gift@pattayarentacar.com", 
          "rak@pattayarentacar.com",
          "pattayarentacar@gmail.com"
        ] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }
    
    function isStaff() {
      let email = getEmail();
      return isSignedIn() && (
        isAdmin() || 
        email.endsWith("@pattayarentacar.com") ||
        email in ["prac.staff@gmail.com", "pattayarentacar@gmail.com"] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["staff", "admin"])
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Master account override
    match /{document=**} {
      allow read, write: if getEmail() == "info@pattayarentacar.com";
    }

    // -------------------------------------------------------------------------
    // 3. PUBLIC COLLECTIONS (READ-ONLY FOR PUBLIC)
    // -------------------------------------------------------------------------

    match /marketing_pages/{pageId} {
      allow get, list: if true;
      allow write: if isStaff();
    }

    match /faqs/{faqId} {
      allow get, list: if true;
      allow write: if isStaff();
    }

    match /cars/{carId} {
      allow get, list: if true;
      allow write: if isStaff();
    }
    match /website_cars/{carId} {
      allow get, list: if true;
      allow write: if isStaff();
    }
    match /ai_knowledge_base/{docId} {
      allow get, list: if true;
      allow write: if isStaff();
    }

    // Pricing
    match /pricing/{pricingId} {
      allow get, list: if true;
      allow write: if isStaff();
    }
    match /pricing_grid/{gridId} {
      allow get, list: if true;
      allow write: if isStaff();
    }
    match /settings/{settingId} {
      allow get: if settingId == 'pricing' || isStaff();
      allow list, write: if isStaff();
    }

    // Marketing & Content
    match /blog_posts/{postId} {
      allow get, list: if true;
      allow write: if isStaff();
    }
    match /reviews/{reviewId} {
      allow get, list, create: if true;
      allow update, delete: if isStaff();
    }
    match /email_templates/{templateId} {
      allow get: if true;
      allow list, write: if isStaff();
    }

    // -------------------------------------------------------------------------
    // 4. PUBLIC CREATABLE COLLECTIONS (WRITE-ONLY/CREATE-ONLY FOR PUBLIC)
    // -------------------------------------------------------------------------

    // Enquiries & Bookings
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow get, list, update, delete: if isStaff();
    }
    match /bookings/{bookingId} {
      allow create: if true;
      allow get, list, update, delete: if isStaff();
    }
    match /customers/{customerId} {
      allow create: if true;
      allow get, list, update, delete: if isStaff();
    }
    
    // System Utilities
    match /system_logs/{logId} {
      allow create: if true;
      allow query: if isStaff();
      allow read, update, delete: if isStaff();
    }
    match /mail/{mailId} {
      allow create: if true;
      allow get, list, update, delete: if isStaff();
    }

    // -------------------------------------------------------------------------
    // 5. STAFF-ONLY COLLECTIONS (READ/WRITE RESTRICTED)
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if isStaff();
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /vehicle_logs/{logId} {
      allow read, write: if isStaff();
    }
    match /transactions/{transactionId} {
      allow read, write: if isStaff();
    }
    match /accounts/{accountId} {
      allow read, write: if isStaff();
    }
    match /finance_summaries/{summaryId} {
      allow read, write: if isStaff();
    }
    match /vehicleFinance/{financeId} {
      allow read, write: if isStaff();
    }
    match /rentals/{rentalId} {
      allow read, write: if isStaff();
    }
    match /rental_photos/{photoId} {
      allow read, write: if isStaff();
    }
    match /system_config/{configId} {
      allow read, write: if isStaff();
    }
    match /review_settings/{settingId} {
      allow read, write: if isStaff();
    }

    // -------------------------------------------------------------------------
    // 6. APP CONFIGURATION (PUBLIC READ)
    // -------------------------------------------------------------------------

    match /app_settings/{settingId} {
      allow get, list: if true;
      allow write: if isStaff();
    }
    match /companyConfig/{docId} {
      allow get, list: if true;
      allow write: if isStaff();
    }
    match /company_config/{docId} {
      allow get, list: if true;
      allow write: if isStaff();
    }
    
    // Test document
    match /test/connection {
      allow get: if true;
    }

    // Hotel Partnership Pages
    match /hotels/{slug} {
      allow get, list: if resource.data.published == true || isStaff();
      allow write: if isStaff();
    }

        // -------------------------------------------------------------------------
        // 7. AGENT GROWTH COLLECTIONS (staff read, knowledge write)
        // -------------------------------------------------------------------------

        match /agent_weeks/{docId} {
          allow read: if isStaff();
        }
        match /agent_actions/{docId} {
          allow read: if isStaff();
        }
        match /agent_knowledge/{docId} {
          allow read, write: if isStaff();
        }
        match /agent_metrics/{docId} {
          allow read: if isStaff();
        }
  }
}
