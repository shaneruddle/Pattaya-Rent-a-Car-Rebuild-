rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // 0. Default Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      // Allow info@ and other specific ones even if unverified for initial setup 
      // but generally we want verified emails for safety.
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.email.lower() == "info@pattayarentacar.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getEmail() {
      return (request.auth.token.email == null) ? "" : request.auth.token.email.lower();
    }

    function isAdmin() {
      return isSignedIn() && (
        getEmail() == "info@pattayarentacar.com" ||
        getEmail() == "gift@pattayarentacar.com" ||
        getEmail() == "rak@pattayarentacar.com" ||
        getEmail() == "pattayarentacar@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isStaff() {
      return isSignedIn() && (
        isAdmin() ||
        getEmail().endsWith("@pattayarentacar.com") ||
        getEmail() == "prac.staff@gmail.com" ||
        getEmail() == "pattayarentacar@gmail.com" ||
        getEmail().endsWith("@googlemail.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['staff', 'admin'])
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.]+$');
    }

    // ===============================================================
    // 1. Root Override for info@pattayarentacar.com
    // ===============================================================
    match /{document=**} {
      allow read, write: if isSignedIn() && getEmail() == "info@pattayarentacar.com";
    }

    // ===============================================================
    // 2. Collection Rules
    // ===============================================================

    // Test connection document
    match /test/connection {
      allow read: if true;
    }

    // Cars: Publicly readable, staff writable
    match /cars/{carId} {
      allow get, list: if true;
      allow write: if isStaff();
    }

    // Website Cars: Publicly readable, staff writable
    match /website_cars/{carId} {
      allow get, list: if true;
      allow write: if isStaff();
    }

    // Bookings: Publicly creatable, staff readable/writable
    match /bookings/{bookingId} {
      allow create: if true;
      allow get, list, update, delete: if isStaff();
    }

    // Transactions: Staff only
    match /transactions/{transactionId} {
      allow get, list, write: if isStaff();
    }

    // Accounts: Staff only
    match /accounts/{accountId} {
      allow get, list, write: if isStaff();
    }

    // Finance Summaries: Staff only
    match /finance_summaries/{summaryId} {
      allow get, list, write: if isStaff();
    }

    // Settings: Staff only, but allow public read for pricing settings
    match /settings/{settingId} {
      allow get: if settingId == 'pricing' || isStaff();
      allow list, write: if isStaff();
    }

    // Pricing & Pricing Grid: Publicly readable, staff writable
    match /pricing/{pricingId} {
      allow get, list: if true;
      allow write: if isStaff();
    }
    match /pricing_grid/{gridId} {
      allow get, list: if true;
      allow write: if isStaff();
    }

    // Enquiries: Publicly creatable, staff readable/writable
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow get, list, update, delete: if isStaff();
    }

    // Users: Self only, but staff can see all
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow list: if isStaff();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && (incoming().role == existing().role || !incoming().keys().contains('role'))) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Vehicle Logs: Staff only
    match /vehicle_logs/{logId} {
      allow get, list, write: if isStaff();
    }

    // Customers: Staff only, but allow public create for new bookings
    match /customers/{customerId} {
      allow create: if true;
      allow get, list, update, delete: if isStaff();
    }

    // System Logs: Staff only, but allow public create
    match /system_logs/{logId} {
      allow create: if true;
      allow get, list, update, delete: if isStaff();
    }

    // System Config: Staff only (contains secrets)
    match /system_config/{configId} {
      allow get, list, write: if isStaff();
    }

    // AI Knowledge Base: Publicly readable, staff writable
    match /ai_knowledge_base/{docId} {
      allow get, list: if true;
      allow write: if isStaff();
    }

    // FAQs: Publicly readable, staff writable
    match /faqs/{faqId} {
      allow get, list: if true;
      allow write: if isStaff();
    }

    // Rentals & Photos: Staff only
    match /rentals/{rentalId} {
      allow get, list, write: if isStaff();
    }
    match /rental_photos/{photoId} {
      allow get, list, write: if isStaff();
    }

    // Mail: Publicly creatable for triggering emails, staff readable/writable
    match /mail/{mailId} {
      allow create: if true;
      allow get, list, update, delete: if isStaff();
    }

    // Blog Posts: Publicly readable, staff writable
    match /blog_posts/{postId} {
      allow get, list: if true;
      allow write: if isStaff();
    }

    // Reviews: Publicly readable and creatable, staff writable
    match /reviews/{reviewId} {
      allow get, list, create: if true;
      allow update, delete: if isStaff();
    }

    // Review Settings: Staff only
    match /review_settings/{settingId} {
      allow get, list, write: if isStaff();
    }
  }
}
