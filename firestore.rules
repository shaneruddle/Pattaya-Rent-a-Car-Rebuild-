rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          ('email' in request.auth.token && 
           (request.auth.token.email.lower() == "info@pattayarentacar.com" ||
            request.auth.token.email.lower() == "pattayarentacar@gmail.com")) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isStaff() {
      return isAuthenticated() &&
        (
          isAdmin() ||
          ('email' in request.auth.token && 
           (request.auth.token.email.lower().matches(".*@pattayarentacar\\.com$") ||
            request.auth.token.email.lower() == "gift@pattayarentacar.com" ||
            request.auth.token.email.lower() == "prac.staff@gmail.com")) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff')
        );
    }

    // Cars: Publicly readable, staff writable
    match /cars/{carId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Website Cars: Publicly readable, staff writable
    match /website_cars/{carId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Bookings: Publicly creatable, staff readable/writable
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    // Transactions & Accounts: Staff only
    match /transactions/{transactionId} {
      allow read, write: if isStaff();
    }
    match /accounts/{accountId} {
      allow read, write: if isStaff();
    }

    // Settings: Staff only
    match /settings/{settingId} {
      allow read, write: if isStaff();
    }

    // Pricing: Publicly readable, staff writable
    match /pricing/{pricingId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Enquiries: Publicly creatable, staff readable/writable
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    // Users: Self only, but admins can see all
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isStaff());
      allow write: if isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId && 
        (!request.resource.data.keys().contains('role') || request.resource.data.role == resource.data.role);
    }

    // Vehicle Logs: Staff only
    match /vehicle_logs/{logId} {
      allow read, write: if isStaff();
    }

    // Customers: Staff only, but allow public create for new bookings
    match /customers/{customerId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    // System Logs: Staff only
    match /system_logs/{logId} {
      allow read, write: if isStaff();
    }

    // System Config: Publicly readable for debugging, staff writable
    match /system_config/{configId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // AI Knowledge Base: Publicly readable, staff writable
    match /ai_knowledge_base/{entryId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Mail: Publicly creatable for triggering emails, staff readable/writable
    match /mail/{mailId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }
  }
}
